# Copy the values you need into .env.
# Do not commit real provider keys.

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000

# Backend runtime
APP_ENV=development
SERVE_FRONTEND=false
FRONTEND_DIST_DIR=

# CORS
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOW_ORIGIN_REGEX=

# Runtime settings and security headers
ALLOW_RUNTIME_SETTINGS=true
SECURITY_HEADERS_ENABLED=true

# Database
DATABASE_URL=sqlite:///./digitize_documents.db
DATABASE_POOL_SIZE=8
DATABASE_MAX_OVERFLOW=0
DATABASE_POOL_TIMEOUT_SECONDS=30

# Storage
STORAGE_BACKEND=local
DOCUMENT_STORAGE_DIR=./storage/documents
RAW_STORAGE_DIR=./storage/raw
PROCESSING_TMP_DIR=./storage/processing
UPLOAD_RETENTION_HOURS=0
RETENTION_CLEANUP_INTERVAL_SECONDS=86400

# Upload and processing limits
UPLOAD_MAX_FILE_BYTES=52428800
UPLOAD_MAX_BATCH_FILES=10000
UPLOAD_CHUNK_FILES=10
UPLOAD_MAX_PDF_PAGES=30
UPLOAD_MAX_IMAGE_PIXELS=50000000
PREPROCESS_MAX_WORKERS=2
DOCUMENT_PAGE_MAX_LONG_EDGE=3000
DOCUMENT_PAGE_JPEG_QUALITY=88
WORKFLOW_MAX_WORKERS=16

# VLM provider
# Use mock for local UI/demo work without external API calls.
# For a local OpenAI-compatible server, set VLM_BASE_URL and increase VLM_TIMEOUT_SECONDS.
# Large local models usually work better with KIE_FIELD_GROUP_SIZE=1 and low concurrency.
VLM_PROVIDER=mock
VLM_API_KEY=
VLM_MODEL_NAME=
VLM_BASE_URL=
VLM_MAX_RETRIES=2
VLM_TIMEOUT_SECONDS=120
VLM_INFERENCE_PARAMS='{"reasoning_effort":"off","thinking":"off","temperature":"0","verbosity":"","max_completion_tokens":"","top_p":"","service_tier":""}'
VLM_MAX_CONCURRENT_REQUESTS=8
KIE_FIELD_GROUP_SIZE=2
LIBREOFFICE_PATH=/usr/bin/soffice

# Optional S3-compatible storage.
OBJECT_STORAGE_ENDPOINT_URL=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_FORCE_PATH_STYLE=false
OBJECT_STORAGE_PREFIX=
